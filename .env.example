# ルート参照用（値はコミットしない）。実際の設定は各パッケージの .env.local に分割してよい。
#
# --- frontend/.env.local（NEXT_PUBLIC_* はブラウザに露出する） ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_API_URL=http://localhost:3001
#
# --- backend/.env.local ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# GEMINI_API_KEY=
